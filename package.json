{
  "name": "ecqqo",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "landing",
    "services/*",
    "shared"
  ],
  "scripts": {
    "dev": "vite dev",
    "dev:backend": "convex dev",
    "dev:connector": "bun run --filter @ecqqo/connector dev",
    "build": "vite build",
